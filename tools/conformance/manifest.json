{
  "schema_version": "0.1.0",
  "description": "List of shims the harness knows about. Each entry says how to build and where the binary lives. The runner skips unbuilt shims with a hint.",
  "shims": [
    {
      "name": "termicap",
      "language": "ada",
      "binary": "shims/ada/termicap/bin/termicap_shim",
      "build": "cd tools/conformance/shims/ada/termicap && alr -n build"
    },
    {
      "name": "supports-color-rust",
      "language": "rust",
      "binary": "shims/rust/supports-color/target/release/supports-color-shim",
      "build": "cd tools/conformance/shims/rust/supports-color && cargo build --release"
    },
    {
      "name": "termenv",
      "language": "go",
      "binary": "shims/go/termenv/bin/termenv-shim",
      "build": "cd tools/conformance/shims/go/termenv && go build -o bin/termenv-shim ."
    },
    {
      "name": "termbg",
      "language": "rust",
      "binary": "shims/rust/termbg/target/release/termbg-shim",
      "build": "cd tools/conformance/shims/rust/termbg && cargo build --release"
    },
    {
      "name": "crossterm",
      "language": "rust",
      "binary": "shims/rust/crossterm/target/release/crossterm-shim",
      "build": "cd tools/conformance/shims/rust/crossterm && cargo build --release"
    },
    {
      "name": "is-unicode-supported",
      "language": "node",
      "binary": "shims/node/is-unicode-supported/shim.mjs",
      "build": "cd tools/conformance/shims/node/is-unicode-supported && npm install"
    },
    {
      "name": "terminal-size",
      "language": "node",
      "binary": "shims/node/terminal-size/shim.mjs",
      "build": "cd tools/conformance/shims/node/terminal-size && npm install"
    },
    {
      "name": "rich",
      "language": "python",
      "binary": "shims/python/rich/run.sh",
      "build": "cd tools/conformance/shims/python/rich && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt"
    }
  ]
}
