with "config/termicap_tests_config.gpr";
with "termicap.gpr";
with "aunit.gpr";

project Termicap_Tests is

   for Source_Dirs use ("src/", "config/");
   for Create_Missing_Dirs use "True";
   for Exec_Dir use "bin";
   for Main use ("termicap_tests.adb");

   --  Coverage mode: "disabled" (default) or "enabled"
   type Coverage_Mode_Type is ("disabled", "enabled");
   Coverage_Mode : Coverage_Mode_Type := external ("TERMICAP_COVERAGE", "disabled");

   --  Object directory varies based on coverage mode
   case Coverage_Mode is
      when "disabled" =>
         for Object_Dir use "obj/" & Termicap_Tests_Config.Build_Profile;
      when "enabled" =>
         for Object_Dir use "obj/coverage";
   end case;

   --  Coverage compiler flags for gcov
   Coverage_Switches := ("-fprofile-arcs", "-ftest-coverage", "-fprofile-update=atomic");

   package Compiler is
      case Coverage_Mode is
         when "disabled" =>
            for Default_Switches ("Ada") use Termicap_Tests_Config.Ada_Compiler_Switches &
               ("-gnatyM120", "-gnaty-u", "-gnat2022");
         when "enabled" =>
            for Default_Switches ("Ada") use Termicap_Tests_Config.Ada_Compiler_Switches &
               ("-gnatyM120", "-gnaty-u", "-gnat2022") & Coverage_Switches;
      end case;
   end Compiler;

   package Linker is
      case Coverage_Mode is
         when "disabled" =>
            null;
         when "enabled" =>
            for Default_Switches ("Ada") use ("--coverage");
      end case;
   end Linker;

   package Binder is
      for Switches ("Ada") use ("-Es"); --  Symbolic traceback
   end Binder;

   package Install is
      for Artifacts (".") use ("share");
   end Install;

   package Format is
      for Width ("Ada") use "120";
      for Charset ("Ada") use "utf-8";
   end Format;

end Termicap_Tests;
