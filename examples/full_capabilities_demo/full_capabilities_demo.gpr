with "termicap.gpr";

project Full_Capabilities_Demo is
   for Source_Dirs use ("src/");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("full_capabilities_demo.adb");
   for Create_Missing_Dirs use "True";

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnatyM120");
   end Compiler;
end Full_Capabilities_Demo;
