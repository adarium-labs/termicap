with "termicap.gpr";

project Win32_Color_Demo is
   for Source_Dirs use ("src/");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Main use ("win32_color_demo.adb");
   for Create_Missing_Dirs use "True";

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat2022", "-gnatyM120");
   end Compiler;
end Win32_Color_Demo;
